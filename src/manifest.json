			"*://manhuaus.com/*",
			"*://toonclash.com/*",
			"*://www.mangatown.com/*",
			"*://manhuaplus.com/*",
			"*://klz9.com/*",
			"*://fanfox.net/*",
			"*://weebcentral.com/*",
