		"https://*.s20.mbcdnsau.org/*",
		"https://*.s21.mbcdnsav.org/*",
		"https://*.s22.mbcdnsaw.org/*",
		"https://*.s23.mbcdnsax.org/*",
		"https://*.s24.mbcdnsay.org/*",
