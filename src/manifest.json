			"Scripts/mangabuddy.js",
			"Scripts/mangago.js",
			"Scripts/mangafire.js",
			"index.js"
		],
		"css": ["Styles/md-style.css"]
	}, {
		"matches": [
			"*://mangafire.to/read/*"
		],
